{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "DebateReport",
  "description": "Output schema for debate-protocol skill",
  "type": "object",
  "required": ["type", "review_id", "verdict", "intensity", "domains_checked", "debate_metadata", "findings", "withdrawn_findings", "dissent"],
  "properties": {
    "type": {
      "type": "string",
      "enum": ["debate-protocol", "debate-protocol-fallback"]
    },
    "review_id": {
      "type": "string",
      "description": "Unique identifier for this debate session"
    },
    "verdict": {
      "type": "string",
      "enum": ["PASS", "FAIL", "CONCERNS"]
    },
    "intensity": {
      "type": "string",
      "enum": ["quick", "standard", "thorough"]
    },
    "domains_checked": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Domain names that were reviewed"
    },
    "debate_metadata": {
      "type": "object",
      "required": ["phases_run", "rounds_completed", "reviewers_spawned"],
      "properties": {
        "phases_run": {
          "type": "array",
          "items": { "type": "integer" }
        },
        "rounds_completed": {
          "type": "integer",
          "minimum": 0
        },
        "reviewers_spawned": {
          "type": "integer",
          "minimum": 1
        },
        "preset": {
          "type": "string",
          "enum": ["default", "security-elevated"]
        }
      }
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "severity", "title", "description", "state", "origin"],
        "properties": {
          "id": { "type": "string" },
          "severity": {
            "type": "string",
            "enum": ["CRITICAL", "HIGH", "MEDIUM", "LOW", "INFO"]
          },
          "title": { "type": "string" },
          "description": { "type": "string" },
          "evidence": { "type": "string" },
          "remediation": { "type": "string" },
          "domains": {
            "type": "array",
            "items": { "type": "string" }
          },
          "state": {
            "type": "string",
            "enum": ["confirmed", "withdrawn", "disputed", "merged", "discovered"]
          },
          "origin": { "type": "string" },
          "corroborated_by": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    },
    "withdrawn_findings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "title", "withdrawal_reason"],
        "properties": {
          "id": { "type": "string" },
          "title": { "type": "string" },
          "withdrawal_reason": { "type": "string" }
        }
      }
    },
    "dissent": {
      "type": "array",
      "description": "Findings where reviewers could not reach consensus",
      "items": {
        "type": "object",
        "required": ["finding_id", "positions"],
        "properties": {
          "finding_id": { "type": "string" },
          "positions": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "reviewer": { "type": "string" },
                "position": { "type": "string" }
              }
            }
          }
        }
      }
    }
  }
}

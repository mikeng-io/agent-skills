{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ContextReport",
  "description": "Output schema for context skill",
  "type": "object",
  "required": ["artifact_type", "domains", "routing", "confidence"],
  "properties": {
    "artifact_type": {
      "type": "string",
      "enum": ["code", "financial", "marketing", "creative", "research", "mixed"]
    },
    "topics": {
      "type": "array",
      "items": { "type": "string" }
    },
    "concerns": {
      "type": "array",
      "items": { "type": "string" }
    },
    "domains": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 1,
      "description": "Selected domain names from domain-registry"
    },
    "domain_experts": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Expert role titles corresponding to selected domains"
    },
    "routing": {
      "type": "string",
      "enum": ["parallel-workflow", "debate-protocol", "deep-council"]
    },
    "debate_intensity": {
      "type": "string",
      "enum": ["quick", "standard", "thorough"],
      "description": "Only present when routing = debate-protocol"
    },
    "confidence": {
      "type": "string",
      "enum": ["high", "medium", "low"]
    },
    "rationale": {
      "type": "string",
      "description": "Brief explanation of routing decision"
    },
    "signals_detected": {
      "type": "object",
      "properties": {
        "files": {
          "type": "array",
          "items": { "type": "string" }
        },
        "topics": {
          "type": "array",
          "items": { "type": "string" }
        },
        "explicit_mentions": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    }
  }
}

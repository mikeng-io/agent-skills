{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://deep-verify.dev/schemas/verification-report.json",
  "title": "Deep Verify Report Schema",
  "description": "JSON Schema for deep-verify output validation",
  "type": "object",
  "required": [
    "verdict",
    "generated",
    "domains_analyzed",
    "experts_consulted",
    "summary",
    "risk_assessment",
    "domain_findings",
    "integration_impact",
    "third_party_perspective"
  ],
  "properties": {
    "verdict": {
      "type": "string",
      "enum": ["PASS", "PASS_WITH_CONCERNS", "FAIL"],
      "description": "Overall verification verdict"
    },
    "generated": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp of report generation"
    },
    "domains_analyzed": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1,
      "description": "List of domains that were analyzed"
    },
    "experts_consulted": {
      "type": "integer",
      "minimum": 3,
      "description": "Number of expert agents consulted (minimum 3: Devil's Advocate, Integration Checker, Third-Party)"
    },
    "summary": {
      "type": "object",
      "required": ["domain_correctness", "risk_assessment", "integration_impact"],
      "properties": {
        "domain_correctness": {
          "type": "object",
          "required": ["status", "details"],
          "properties": {
            "status": {
              "type": "string",
              "enum": ["PASS", "CONCERNS"]
            },
            "details": {
              "type": "string"
            }
          }
        },
        "risk_assessment": {
          "type": "object",
          "required": ["status", "details"],
          "properties": {
            "status": {
              "type": "string",
              "enum": ["PASS", "CONCERNS", "FAIL"]
            },
            "details": {
              "type": "string"
            }
          }
        },
        "integration_impact": {
          "type": "object",
          "required": ["status", "details"],
          "properties": {
            "status": {
              "type": "string",
              "enum": ["PASS", "CONCERNS"]
            },
            "details": {
              "type": "string"
            }
          }
        }
      }
    },
    "risk_assessment": {
      "type": "object",
      "required": ["scenarios", "hidden_assumptions"],
      "properties": {
        "scenarios": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["scenario", "likelihood", "impact", "evidence", "mitigation"],
            "properties": {
              "scenario": {
                "type": "string",
                "description": "Description of what went wrong in the pre-mortem"
              },
              "likelihood": {
                "type": "string",
                "enum": ["LOW", "MEDIUM", "HIGH"]
              },
              "impact": {
                "type": "string",
                "enum": ["LOW", "MEDIUM", "HIGH", "CRITICAL"]
              },
              "evidence": {
                "type": "string",
                "description": "What suggests this could happen"
              },
              "mitigation": {
                "type": "string",
                "description": "How to prevent this scenario"
              }
            }
          },
          "minItems": 1
        },
        "hidden_assumptions": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["assumption", "risk_if_false"],
            "properties": {
              "assumption": {
                "type": "string",
                "description": "What we're assuming"
              },
              "risk_if_false": {
                "type": "string",
                "description": "What happens if assumption is wrong"
              }
            }
          }
        }
      }
    },
    "domain_findings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["domain", "findings"],
        "properties": {
          "domain": {
            "type": "string",
            "description": "Domain name"
          },
          "findings": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["severity", "description", "evidence"],
              "properties": {
                "severity": {
                  "type": "string",
                  "enum": ["CRITICAL", "HIGH", "MEDIUM", "LOW"]
                },
                "description": {
                  "type": "string",
                  "description": "Issue or observation"
                },
                "evidence": {
                  "type": "string",
                  "description": "Reference to specific content"
                },
                "fix": {
                  "type": "string",
                  "description": "Recommendation if applicable"
                }
              }
            }
          }
        }
      }
    },
    "integration_impact": {
      "type": "object",
      "required": ["affected_components", "dependencies", "coordination_required", "risks"],
      "properties": {
        "affected_components": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "List of affected components/systems"
        },
        "dependencies": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "List of dependencies"
        },
        "coordination_required": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "What needs to be coordinated"
        },
        "risks": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["area", "risk"],
            "properties": {
              "area": {
                "type": "string",
                "description": "Affected area"
              },
              "risk": {
                "type": "string",
                "description": "Risk description"
              }
            }
          }
        }
      }
    },
    "third_party_perspective": {
      "type": "object",
      "required": ["clarity_score", "questions", "suggestions"],
      "properties": {
        "clarity_score": {
          "type": "string",
          "enum": ["HIGH", "MEDIUM", "LOW"]
        },
        "questions": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Questions a newcomer would ask"
        },
        "suggestions": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Constructive suggestions"
        }
      }
    }
  }
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "council-artifact",
  "title": "Council Artifact Frontmatter Schema",
  "description": "YAML frontmatter schema for all council artifacts written to .outputs/",
  "type": "object",
  "properties": {
    "skill": {
      "type": "string",
      "enum": ["agent-council", "deep-review", "deep-audit", "deep-verify", "deep-research"],
      "description": "The orchestrator or thin-wrapper skill that produced this artifact"
    },
    "tier": {
      "type": "integer",
      "enum": [0, 1, 2, 3],
      "description": "Tier of the agent council that ran; canonical for agent-council artifacts"
    },
    "mode": {
      "type": "string",
      "enum": ["review", "audit", "finding-driven", "research", "brainstorm", "design", "synthesis"],
      "description": "Mode the council ran in; canonical for agent-council artifacts"
    },
    "task_type": {
      "type": "string",
      "enum": ["review", "audit", "research", "analysis", "planning", "implementation"],
      "description": "Authority and output profile for this council run"
    },
    "guardian_enforced": {
      "type": "boolean",
      "description": "Whether Guardian validated registration/preflight for this run"
    },
    "agent_council_tier": {
      "type": "integer",
      "enum": [1, 2, 3],
      "description": "Legacy wrapper field for the tier of the agent council that ran"
    },
    "agent_council_mode": {
      "type": "string",
      "enum": ["review", "audit", "finding-driven", "research", "brainstorm", "design", "synthesis"],
      "description": "Legacy wrapper field for the mode the council ran in"
    },
    "session_id": {
      "type": "string",
      "pattern": "^[a-zA-Z0-9][a-zA-Z0-9_.-]*$",
      "minLength": 1,
      "description": "Unique session identifier"
    },
    "timestamp": {
      "type": "string",
      "description": "ISO-8601 timestamp of when the council completed"
    },
    "verdict": {
      "oneOf": [
        {"type": "string", "enum": ["PASS", "FAIL", "CONCERNS"]},
        {"type": "null"}
      ],
      "description": "Verdict for review/audit/finding-driven modes; null for research/brainstorm/design"
    },
    "domains": {
      "type": "array",
      "items": {"type": "string"},
      "description": "Domains the council covered"
    },
    "context_summary": {
      "type": "string",
      "description": "Brief context description"
    }
  },
  "required": ["skill", "session_id", "timestamp", "domains"],
  "allOf": [
    {
      "if": {
        "properties": {
          "skill": {"const": "agent-council"}
        }
      },
      "then": {
        "required": ["tier", "mode", "task_type"]
      }
    },
    {
      "if": {
        "properties": {
          "skill": {"enum": ["deep-review", "deep-audit", "deep-verify", "deep-research"]}
        }
      },
      "then": {
        "required": ["agent_council_tier", "agent_council_mode"]
      }
    },
    {
      "if": {
        "properties": {
          "skill": {"const": "deep-audit"}
        }
      },
      "then": {
        "required": ["requirements_audited", "verdict"],
        "properties": {
          "requirements_audited": {
            "type": "array",
            "items": {"type": "string"}
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "skill": {"const": "deep-verify"}
        }
      },
      "then": {
        "required": ["requirements_verified", "verdict"],
        "properties": {
          "requirements_verified": {
            "type": "array",
            "items": {"type": "string"}
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "skill": {"enum": ["deep-review", "deep-audit", "deep-verify"]}
        }
      },
      "then": {
        "required": ["verdict"]
      }
    }
  ]
}
